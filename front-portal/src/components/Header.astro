---
const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/productos", label: "Productos" },
  { href: "/indicadores", label: "Indicadores" },
  { href: "/simulador", label: "Simulador" },
];
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <div class="shrink-0 flex items-center">
        <a href="/" class="flex items-center space-x-2">
          <svg
            class="h-8 w-8 text-primary-600"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.31-8.86c-1.77-.45-2.34-.94-2.34-1.67 0-.84.79-1.43 2.1-1.43 1.38 0 1.9.66 1.94 1.64h1.71c-.05-1.34-.87-2.57-2.49-2.97V5H10.9v1.69c-1.51.32-2.72 1.3-2.72 2.81 0 1.79 1.49 2.69 3.66 3.21 1.95.46 2.34 1.15 2.34 1.87 0 .53-.39 1.39-2.1 1.39-1.6 0-2.23-.72-2.32-1.64H8.04c.1 1.7 1.36 2.66 2.86 2.97V19h2.34v-1.67c1.52-.29 2.72-1.16 2.73-2.77-.01-2.2-1.9-2.96-3.66-3.42z"
            ></path>
          </svg>
          <span class="text-xl font-bold text-gray-900">Billetera Digital</span>
        </a>
      </div>

      <!-- Navigation Links -->
      <div class="hidden mdx:flex mdx:space-x-8">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-gray-900 hover:text-primary-600 px-3 py-2 text-sm font-medium transition-colors"
            >
              {link.label}
            </a>
          ))
        }
      </div>

      <!-- CTA Buttons -->
      <div class="hidden mdx:flex mdx:items-center mdx:space-x-4">
        <a
          href="/registro"
          class="text-primary-600 hover:text-primary-700 px-4 py-2 text-sm font-medium"
        >
          Registrarse
        </a>
        <a href="http://localhost:3000/login" class="btn-primary text-sm">
          Ingresar
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="mdx:hidden">
        <button
          type="button"
          class="text-gray-700 hover:text-primary-600"
          id="mobile-menu-button"
          aria-label="Abrir menú de navegación"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <svg
            class="h-6 w-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div class="mdx:hidden hidden" id="mobile-menu">
      <div class="px-2 pt-2 pb-3 space-y-1">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="block text-gray-700 hover:text-primary-600 hover:bg-gray-50 px-3 py-2 rounded-md text-base font-medium"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href="/registro"
          class="block text-gray-700 hover:text-primary-600 hover:bg-gray-50 px-3 py-2 rounded-md text-base font-medium"
        >
          Registrarse
        </a>
        <a
          href="http://localhost:3000/login"
          class="block btn-primary text-center text-base mt-2"
        >
          Ingresar
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const button = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");

  button?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
