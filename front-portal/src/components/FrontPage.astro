---

---

<main>
  <!-- Main Hero Section -->
  <section class="bg-linear-to-br from-primary-600 to-primary-800 text-white">
    <div class="section-container py-20 md:py-32">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h1
            class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight"
          >
            Tu dinero, siempre a tu alcance
          </h1>
          <p class="text-lg md:text-xl mb-8 text-primary-100">
            Gestiona tus finanzas de forma segura y simple. Transferencias
            instantáneas, cuentas digitales y mucho más.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="/registro"
              class="bg-white text-primary-600 hover:bg-gray-50 font-semibold py-4 px-8 rounded-lg transition-colors text-center"
            >
              Abrir Cuenta Gratis
            </a>
            <a
              href="/productos"
              class="border-2 border-white hover:bg-white/10 font-semibold py-4 px-8 rounded-lg transition-colors text-center"
            >
              Conocer Productos
            </a>
          </div>
        </div>
        <div class="hidden md:block">
          <svg
            class="w-full h-auto"
            viewBox="0 0 500 400"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <rect
              x="50"
              y="80"
              width="400"
              height="250"
              rx="20"
              fill="white"
              fill-opacity="0.1"></rect>
            <rect
              x="70"
              y="100"
              width="180"
              height="120"
              rx="10"
              fill="white"
              fill-opacity="0.2"></rect>
            <rect
              x="270"
              y="100"
              width="160"
              height="50"
              rx="8"
              fill="white"
              fill-opacity="0.15"></rect>
            <rect
              x="270"
              y="170"
              width="160"
              height="50"
              rx="8"
              fill="white"
              fill-opacity="0.15"></rect>
            <circle cx="130" cy="280" r="30" fill="#22c55e" fill-opacity="0.8"
            ></circle>
            <path
              d="M120 280 L128 288 L142 272"
              stroke="white"
              stroke-width="3"
              stroke-linecap="round"></path>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="section-container">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        ¿Por qué elegirnos?
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Tecnología de punta para gestionar tu dinero con total seguridad y
        comodidad.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Feature 1 -->
      <div
        class="bg-white p-8 rounded-xl shadow-sm hover:shadow-md transition-shadow"
      >
        <div
          class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-6"
        >
          <svg
            class="w-6 h-6 text-primary-600"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
            ></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-3">100% Seguro</h3>
        <p class="text-gray-600">
          Protegemos tu dinero con autenticación de dos factores y encriptación
          de grado bancario.
        </p>
      </div>

      <!-- Feature 2 -->
      <div
        class="bg-white p-8 rounded-xl shadow-sm hover:shadow-md transition-shadow"
      >
        <div
          class="w-12 h-12 bg-secondary-100 rounded-lg flex items-center justify-center mb-6"
        >
          <svg
            class="w-6 h-6 text-secondary-600"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-3">
          Transferencias Instantáneas
        </h3>
        <p class="text-gray-600">
          Envía y recibe dinero al instante, 24/7, sin costos adicionales entre
          cuentas.
        </p>
      </div>

      <!-- Feature 3 -->
      <div
        class="bg-white p-8 rounded-xl shadow-sm hover:shadow-md transition-shadow"
      >
        <div
          class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-6"
        >
          <svg
            class="w-6 h-6 text-primary-600"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            ></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-3">Sin Comisiones</h3>
        <p class="text-gray-600">
          Mantención gratuita, sin costos ocultos. Tu dinero es tuyo, sin cargos
          mensuales.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-primary-50">
    <div class="section-container text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
        Abre tu cuenta en minutos
      </h2>
      <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
        Solo necesitas tu RUT y un correo electrónico. Sin papeleos ni visitas
        al banco.
      </p>
      <a href="/registro" class="btn-primary inline-block text-lg">
        Comenzar Ahora
      </a>
    </div>
  </section>
</main>
